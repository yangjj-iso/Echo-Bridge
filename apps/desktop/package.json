{
  "name": "@echo-bridge/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run typecheck && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "lint": "eslint src",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@echo-bridge/audio": "file:../../packages/audio",
    "@echo-bridge/captions": "file:../../packages/captions",
    "@echo-bridge/shared": "file:../../packages/shared",
    "@echo-bridge/transcription": "file:../../packages/transcription",
    "@echo-bridge/translation": "file:../../packages/translation",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.3",
    "lucide-react": "^0.561.0",
    "vite": "^8.0.16",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.3"
  }
}
