{
  "name": "echo-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop AI simultaneous interpretation assistant for live system audio.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build:renderer -w @echo-bridge/desktop",
    "build:ts": "tsc -b",
    "check": "npm run typecheck && npm run lint",
    "dev": "concurrently -k \"npm run dev -w @echo-bridge/api\" \"npm run dev -w @echo-bridge/desktop\"",
    "dev:api": "npm run dev -w @echo-bridge/api",
    "dev:desktop": "npm run dev -w @echo-bridge/desktop",
    "format": "prettier --write .",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
